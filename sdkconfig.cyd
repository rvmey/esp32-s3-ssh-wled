# Hardware variant: TRIGGERcmd CYD (ESP32-2432S028R), using Core2-compatible display profile
CONFIG_HARDWARE_CYD=y

# Console: UART0 (classic ESP32)
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y

# WebSocket receive buffer (must hold a full Socket.IO frame + overhead)
CONFIG_WS_BUFFER_SIZE=8192

# Common ESP32 WROVER-style memory setup for CYD-class boards.
# Many ESP32-2432S028R boards have no PSRAM chip at all (PSRAM ID read
# returns 0xffffffff), which aborts cpu_start and boot-loops unless we
# allow booting without external RAM.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_IGNORE_NOTFOUND=y

# This board's actual flash chip is 4MB (probed at boot as 4096k), even
# though some ESP32-2432S028R listings advertise 16MB.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

# Dedicated partition table sized for the 4MB flash (Core2's table needs 5MB+)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_cyd.csv"

# Bluetooth classic stack (for headset/speaker discovery)
CONFIG_BT_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y
CONFIG_BT_CLASSIC_ENABLED=y
CONFIG_BT_A2DP_ENABLE=y
CONFIG_BT_SSP_ENABLED=y
# CONFIG_BT_BLE_ENABLED is not set
# CONFIG_BT_GOEPC_ENABLED is not set
CONFIG_BT_ALLOCATION_FROM_SPIRAM_FIRST=y
CONFIG_BTDM_CTRL_MODE_BR_EDR_ONLY=y
# CONFIG_BTDM_CTRL_MODE_BLE_ONLY is not set
# CONFIG_BTDM_CTRL_MODE_BTDM is not set

# TLS — CA bundle. Use the smaller "common" bundle (not FULL) on this
# no-PSRAM board: the full ~200-cert bundle costs extra internal SRAM at
# init time, and that plus the default 16KB SSL input buffer was enough to
# make mbedtls_ssl_setup() fail with -0x008D (PSA_ERROR_INSUFFICIENT_MEMORY)
# during the /pair HTTPS request. CMN still covers triggercmd.com's CA.
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_CMN=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_CROSS_SIGNED_VERIFY=y

# TLS diagnostic mode for websocket attempt 4 (no-verify path)
CONFIG_ESP_TLS_INSECURE=y
CONFIG_ESP_TLS_SKIP_SERVER_CERT_VERIFY=y

# Dynamic mbedTLS TX/RX buffers — the real fix for the /pair TLS failure on
# this no-PSRAM board. Diagnostic builds (2.0.407/408, mbedTLS debug + pk_rsa
# instrumentation) proved the server's RSA leaf pubkey imports fine via PSA
# (3x set_pubkey, key_len=270, all succeed); the handshake then dies inside
# mbedtls_x509_crt_parse_der() with -141 / -0x008D = PSA_ERROR_INSUFFICIENT_
# MEMORY while parsing the 3-cert chain. Earlier this surfaced one alloc
# sooner as -0x3B00 (psa_import_key OOM masked to PK_INVALID_PUBKEY). Root
# cause is internal-SRAM exhaustion: Core2 has PSRAM, the CYD does not, and
# BT-Classic/A2DP/Bluedroid already pins ~50KB+ of internal RAM, leaving only
# ~39KB free / ~20-26KB largest block at handshake time.
#
# MBEDTLS_DYNAMIC_BUFFER stops pre-allocating the full IN+OUT buffers at
# ssl_setup and instead allocates the RX buffer to the actual record size on
# demand (freeing it once the upper layer consumes the data) and frees the TX
# buffer when idle — freeing ~8-12KB of contiguous heap during the cert-chain
# parse window. It auto-selects MBEDTLS_ASYMMETRIC_CONTENT_LEN; IN/OUT below
# act as ceilings, not fixed allocations. FREE_CONFIG_DATA frees key/DHM data
# after handshake (safe: esp-tls builds a fresh config per connection).
# v2.0.424 TRIED lowering OUT_CONTENT_LEN to 2048 to shrink the dynamic OUT
# buffer alloc (4437B at 4096) that the first idle->active WS write (the
# 1-byte EIO pong "3" replying to the server's EIO ping "2") needs ~20s after
# connect. That made things WORSE: the TLS handshake itself then failed with
# "Dynamic Impl: alloc(5473/2389 bytes) failed" on EVERY attempt, even at a
# healthy largest=34816 (vs. 4096 handshaking fine at largest=18432 in
# v2.0.423). The handshake's heap requirement does not shrink monotonically
# with OUT_CONTENT_LEN here -- reverted to 4096. DO NOT lower this again
# without re-testing the handshake itself (not just the post-connect pong).
# The post-connect pong-write OOM needs a different fix (reduce heap used by
# the deferred mp3/jpeg scan + config server + display restore in the first
# ~20s after connect).
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=8192
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=4096
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y
CONFIG_MBEDTLS_DYNAMIC_FREE_CONFIG_DATA=y

# v2.0.415: even with DYNAMIC_BUFFER, /pair handshakes after the first one
# failed with "Dynamic Impl: alloc(5473 bytes) failed". Heap-trace LEAKS
# diagnosis (v2.0.413/414, since removed) found the first TLS handshake
# leaves ~418 bytes of UNAVOIDABLE one-time subsystem warm-up alive — the
# HW-SHA engine lock queues (2x 84B FreeRTOS queues from
# esp_sha_try_lock_engine -> xQueueGenericCreate), lwip memp pool blocks,
# and a WiFi/coex TX buffer — which land near the TOP of the 111KB heap
# region and cap the largest contiguous block from ~21KB down to ~12-13KB,
# just below the handshake's peak need (5473B cert-record RX buffer + the
# 3-cert-chain parse copies). Two levers to clear that threshold:
#
# 1) Disable HW-SHA so mbedTLS uses software SHA and never creates the
#    esp_sha engine-lock queues (removes that survivor class entirely;
#    handshake is a few ms slower, no correctness impact — wolfSSH already
#    uses software crypto via the wolfssl user_settings patches).
CONFIG_MBEDTLS_HARDWARE_SHA=n
#
# 2) Trim WiFi/lwip buffers to raise the baseline largest contiguous block
#    well above the ~17KB handshake peak so warm-up fragmentation no longer
#    matters. App traffic is small JSON, so halving the WiFi dynamic TX
#    buffer pool and the TCP windows (5760 -> 2880 = 2x MSS) costs no
#    real-world throughput here.
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=16
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=2880
CONFIG_LWIP_TCP_WND_DEFAULT=2880

# NOTE: do NOT enable CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC on this board. It
# forces all mbedTLS allocations to use MALLOC_CAP_SPIRAM, which always
# fails on boards with no PSRAM (psa_crypto_init() then aborts cpu_start
# with "init function ... has failed (0xffffffff)"). mbedTLS buffers fall
# back to internal SRAM instead.

# Conservative watchdog and CPU settings matching existing ESP32 Core2 profile
CONFIG_ESP_INT_WDT_TIMEOUT_MS=2000
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_ESP32_DEFAULT_CPU_FREQ_240=y
