# Hardware variant: TRIGGERcmd ATOM Echo (M5Stack ATOM Echo — ESP32-PICO-D4)
CONFIG_HARDWARE_TCMD_ATOM_ECHO=y

# Console: UART0 via FTDI bridge (classic ESP32 has no USB-JTAG)
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y

# TLS — full CA bundle (includes roots for triggercmd.com and api.openai.com)
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
# Allow cross-signed chain verification
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_CROSS_SIGNED_VERIFY=y

# Flash size: 4 MB (ATOM Echo)
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

# Custom partition table — larger factory slot for embedded PCM audio clips
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_tcmd_atom_echo.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x8000

# Increase heap for TLS + HTTP client buffers
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=16384
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=4096
