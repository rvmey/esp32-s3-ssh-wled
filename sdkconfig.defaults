# Increase main stack size for wolfSSH (must be >= 10500 for wolfSSL RSA)
CONFIG_ESP_MAIN_TASK_STACK_SIZE=12288
CONFIG_ESP_WOLFSSL_NO_STACK_SIZE_BUILD_WARNING=y
CONFIG_ESP_ENABLE_WOLFSSH=y

# WiFi
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=4
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=8
CONFIG_ESP32S3_DEFAULT_CPU_FREQ_240=y

# Networking
CONFIG_LWIP_MAX_SOCKETS=8
CONFIG_LWIP_SO_RCVBUF=y

# NVS partition for storing SSH host key
CONFIG_NVS_ENCRYPTION=n

# Increase TCP MSS for better SSH throughput
CONFIG_LWIP_TCP_MSS=1436

# wolfSSH / wolfSSL need a large stack
CONFIG_LWIP_TCPIP_TASK_STACK_SIZE=4096

# Partition table
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y

# Console: route to native USB (USB-Serial-JTAG) – board has no UART bridge
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
